APP_NAME=EWMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

ALLOW_REGISTRATION=false
ALLOW_ACCOUNT_DELETION=false

# Lets Administrators/CEO trigger the release sequence from the app itself.
# Leave disabled unless this host owns its own working directory (see docs/DEPLOYMENT.md).
DEPLOY_SELF_UPDATE_ENABLED=false
DEPLOY_BRANCH=main
DEPLOY_TIMEOUT=600

# Leave GOOGLE_CLIENT_ID blank to disable Google sign-in entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
GOOGLE_ALLOWED_DOMAINS=

# Leave BIGQUERY_PROJECT_ID blank to disable analytics syncs entirely; each
# sync job records a failed health-check row instead of crashing.
BIGQUERY_PROJECT_ID=
BIGQUERY_LOCATION=US
# Path to a service account key file, e.g. storage/app/gcp/bigquery.json
# (that directory is gitignored). Leave blank to use Application Default
# Credentials instead.
BIGQUERY_CREDENTIALS_PATH=
GA4_BIGQUERY_DATASET_PATTERN=analytics_{property_id}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ewms
DB_USERNAME=ewms
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="ewms@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
